# ─── Server Configuration ──────────────────────────────────────────
# The port where the Go backend will listen (inside the container)
PORT=8080

# ─── Worker Configuration ──────────────────────────────────────────
# Maximum number of concurrent build/compile jobs. 
# Increasing this requires more CPU/RAM on the VPS.
MAX_WORKERS=3

# ─── Docker Runner Configuration ──────────────────────────────────
# The name of the sibling container that actually runs Stellar CLI.
# This should match the 'container_name' of your runner service.
RUNNER_CONTAINER=soroban-runner

# The root directory for user workspaces inside the backend container.
WORKSPACE_DIR=/app/workspaces
